# LLM provider — pick one (OpenRouter takes priority if set)
OPENROUTER_API_KEY=sk-or-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Model name (OpenRouter format: provider/model-name)
LLM_MODEL=anthropic/claude-sonnet-4-5
# LLM_MODEL=openai/gpt-4o
# LLM_MODEL=google/gemini-2.0-flash

# PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://marketing:marketing_local@localhost:5432/marketing

# Sandbox (added later)
SANDBOX_URL=http://localhost:8100
